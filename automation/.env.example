# SWELL Instagram Automation Bot - Configuration
# Copy this file to .env and fill in your values

# Instagram Credentials (stored locally only)
IG_USERNAME=your_username
IG_PASSWORD=your_password

# Daily Limits (keep these conservative to avoid detection)
MAX_LIKES_PER_DAY=20
MAX_FOLLOWS_PER_DAY=10

# Target Hashtags (comma-separated, without #)
# Bot will like recent posts from these hashtags
TARGET_HASHTAGS=surfing,waves,oceanlife,sunset

# Target Accounts (comma-separated, without @)
# Bot will follow recent followers of these accounts
TARGET_ACCOUNTS=natgeo,surfline,thesearch

# Delay between actions in seconds (randomized within range)
# Higher = safer but slower
MIN_DELAY=30
MAX_DELAY=120
